<adonisControls:AdonisWindow x:Class="PalCalc.UI.AppWindow"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:adonisControls="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
                             xmlns:itl="clr-namespace:PalCalc.UI.Localization"
                             xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
                             xmlns:vmc="clr-namespace:PalCalc.UI.ViewModel.Converters"
                             xmlns:ui="clr-namespace:PalCalc.UI"
                             xmlns:v="clr-namespace:PalCalc.UI.View"
                             d:DataContext="{d:DesignInstance Type=ui:AppWindowViewModel}"
                             mc:Ignorable="d"
                             Title="{itl:LocalizedText LC_WINDOW_TITLE}"
                             Width="1280" Height="720"
                             IconVisibility="Collapsed">
    <Window.Resources>
        <vmc:ValueVisibilityConverter x:Key="VVC" />
    </Window.Resources>
    <Window.Style>
        <Style TargetType="Window" BasedOn="{StaticResource {x:Type Window}}" />
    </Window.Style>
    <DockPanel>
        <Grid DockPanel.Dock="Top"
              Visibility="{Binding ShowToolbar, Converter={StaticResource VVC}}">
            <v:AppToolbar DataContext="{Binding ToolbarVM}" />
        </Grid>

        <ContentControl Content="{Binding Content}" />
    </DockPanel>
</adonisControls:AdonisWindow>
