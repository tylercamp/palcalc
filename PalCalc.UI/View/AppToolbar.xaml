<UserControl x:Class="PalCalc.UI.View.AppToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
             xmlns:vm="clr-namespace:PalCalc.UI.ViewModel"
             xmlns:vmc="clr-namespace:PalCalc.UI.ViewModel.Converters"
             xmlns:itl="clr-namespace:PalCalc.UI.Localization"
             xmlns:local="clr-namespace:PalCalc.UI.View"
             mc:Ignorable="d" 
             d:DataContext="{x:Static vm:AppToolbarViewModel.DesignerInstance}"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <vmc:ValueBoolConverter x:Key="VBC" />
    </UserControl.Resources>
    <Menu DockPanel.Dock="Top" Background="{DynamicResource {x:Static adonisUi:Brushes.Layer2BackgroundBrush}}">
        <MenuItem Header="{itl:LocalizedText LC_LANGUAGE}" ItemsSource="{Binding Locales}" Padding="5">
            <MenuItem.ItemContainerStyle>
                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                    <Setter Property="Header" Value="{Binding Label}" />
                    <Setter Property="IsCheckable" Value="True" />
                    <Setter Property="IsChecked" Value="{Binding IsSelected}" />
                    <Setter Property="Command" Value="{Binding SelectCommand}" />
                </Style>
            </MenuItem.ItemContainerStyle>
        </MenuItem>
        <MenuItem Header="Debug" Padding="5" Name="DebugMenuItem">
            <MenuItem Header="Translation Debugger" Click="TranslationDebugger_Click" />
        </MenuItem>
        <MenuItem Header="{itl:LocalizedText LC_HELP}" Padding="5">
            <MenuItem Command="{Binding ExportCrashLogCommand}" Header="{itl:LocalizedText LC_EXPORT_CRASH_LOG}" />
            <MenuItem Command="{Binding ForceCheckForUpdatesCommand}" Header="{itl:LocalizedText LC_NAV_FORCE_CHECK_UPDATES}" />
            <MenuItem Command="{Binding OpenAboutWindowCommand}" Header="{itl:LocalizedText LC_ABOUT_APP}" />
        </MenuItem>
    </Menu>
</UserControl>
